shader_parameter/tile_scale = Vector2(4, 4)
shader_parameter/scroll_speed = Vector2(0.2, 0.1)
shader_parameter/sprite_aspect = Vector2(1.7778, 1)
shader_parameter/texture_pixel_size = 0.00195313
shader_parameter/fps = 5.0
