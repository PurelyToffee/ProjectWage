[sub_resource type="Resource" id="Resource_tgrf6"]
script = ExtResource("4_qcf34")
title = "Brawlers and Kick"
description = "In front of you are [color=red]Brawlers[/color].
They are meelee enemies that will try to close the distance to hit you!"
metadata/_custom_type_script = "uid://duub2ne1m1uaf"

[sub_resource type="Resource" id="Resource_8nlbc"]
script = ExtResource("4_qcf34")
title = "Combat"
description = "Use your guns to destroy the [color=red]red[/color] wall to progress."
metadata/_custom_type_script = "uid://duub2ne1m1uaf"

[sub_resource type="Resource" id="Resource_2ymwt"]
script = ExtResource("4_qcf34")
title = "Brawlers and Kick"
description = "You should keep your distance, and shoot them in the [color=red]head[/color]!
However, if you're brave, you can attempt to parry their attacks by [color=red]kicking[/color] just as they're about to attack! 
To kick, press [color=red]F[color]."
metadata/_custom_type_script = "uid://duub2ne1m1uaf"

[sub_resource type="Resource" id="Resource_o86wv"]
script = ExtResource("4_qcf34")
title = "Power Kick"
description = "Under certain conditions, you'll see that enemies will gain a [color=yellow]yellow [color=red]outline[/color].
This means that they are [color=red]Vulnerable[/color]"
metadata/_custom_type_script = "uid://duub2ne1m1uaf"

[sub_resource type="Resource" id="Resource_bq5g7"]
script = ExtResource("4_qcf34")
title = "Power Kick"
description = "If while airborne, you kick an enemy in this state, you will perform a [color=red]Power Kick[/color], which will grant you more speed and vertical velocity.
Sometimes, it might even have some extra effects."
metadata/_custom_type_script = "uid://duub2ne1m1uaf"

